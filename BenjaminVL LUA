función local makeDraggable(frame, handle)
    arrastre local = falso
    Entrada de arrastre local, posición del ratón, posición del marco
    manejador.InputBegan:Connect(function(input)
        si input.UserInputType == Enum.UserInputType.MouseButton1 o
           Si input.UserInputType es igual a Enum.UserInputType.Touch, entonces
            arrastrando = verdadero
            mousePos = input.Position
            framePos = frame.Position
            entrada.Cambiada:Conectar(función()
                Si input.UserInputState == Enum.UserInputState.End entonces
                    arrastrando = falso
                fin
            fin)
        fin
    fin)
    manejador.InputChanged:Connect(function(input)
        si input.UserInputType == Enum.UserInputType.MouseMovement o
           Si input.UserInputType es igual a Enum.UserInputType.Touch, entonces
            dragInput = entrada
        fin
    fin)
    UserInputService.InputChanged:Connect(function(input)
        si input == dragInput y arrastrando entonces
            delta local = input.Position - mousePos
            frame.Position = UDim2.new(
                framePos.X.Scale, framePos.X.Offset + delta.X,
                framePos.Y.Scale, framePos.Y.Offset + delta.Y
            )
        fin
    fin)
fin

