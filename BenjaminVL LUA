función local startVoid(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    Si no es hrp, entonces regresar fin
    hrp.CFrame = CFrame.new(hrp.Position.X, VOID_Y, hrp.Position.Z)
    Si fallLoop está presente, entonces fallLoop:Disconnect() fallLoop = nil fin
    fallLoop = RunService.Heartbeat:Conectar(función()
        si hrp y hrp.Parent entonces
            Si hrp.Position.Y > VOID_Y + 5000 entonces
                hrp.CFrame = CFrame.new(hrp.Position.X, VOID_Y, hrp.Position.Z)
            fin
            hrp.AssemblyLinearVelocity = Vector3.new(0, -500, 0)
            StatusLabel.Text = "void activo | Y: " .. string.format("%.0f", hrp.Position.Y)
        fin
    fin)
fin

función local startVoidSpam(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    Si no es hrp, entonces regresar fin
    Si voidSpamLoop está presente, entonces voidSpamLoop:Disconnect() voidSpamLoop = nil
    voidSpamLoop = RunService.Heartbeat:Connect(función()
        si hrp y hrp.Parent entonces
            hrp.CFrame = CFrame.new(hrp.Position.X, VOID_Y, hrp.Position.Z)
            hrp.AssemblyLinearVelocity = Vector3.new(0, -9999, 0)
            StatusLabel.Text = "void spam | Y: " .. string.format("%.0f", hrp.Position.Y)
        fin
    fin)
fin

función local startOrbit(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    Si no es hrp, entonces regresar fin
    Si orbitLoop está presente, entonces orbitLoop:Disconnect() orbitLoop = nil fin
    orbitLoop = RunService.Heartbeat:Connect(function()
        si hrp y hrp.Parent entonces
            orbitAngle = orbitAngle + orbitSpeed ​​* 0,05
            hrp.CFrame = CFrame.new(
                math.cos(ángulo de órbita) * radio de órbita,
                ÓRBITA_Y,
                math.sin(ángulo de órbita) * radio de órbita
            )
            hrp.AssemblyLinearVelocity = Vector3.new(0, -9999, 0)
            StatusLabel.Text = "orbit spam | Y: " .. string.format("%.0f", hrp.Position.Y)
        fin
    fin)
fin

